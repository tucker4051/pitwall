{
  "name": "@pitwall/backend",
  "version": "0.1.0",
  "private": true,
  "description": "PitWall backend live data service.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:openf1-fixtures": "tsx test/openf1-mapper-probe.ts",
    "validate:incremental-live-state": "tsx test/incremental-live-state-probe.ts",
    "validate:session-scoped-state": "tsx test/session-scoped-state-probe.ts",
    "validate:pipeline-stabilization": "tsx test/pipeline-stabilization-probe.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "mqtt": "^5.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
