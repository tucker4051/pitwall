# OpenF1 credentials
# Backend-only. Never expose these with NEXT_PUBLIC_ prefixes.
DATA_MODE=mock

OPENF1_USERNAME=username_here
OPENF1_PASSWORD=password_here

OPENF1_TOKEN_URL=https://api.openf1.org/token
OPENF1_MQTT_HOST=mqtt.openf1.org
OPENF1_MQTT_PORT=8883
OPENF1_MQTT_CLIENT_USERNAME=pitwall
OPENF1_MQTT_WS_URL=wss://mqtt.openf1.org:8084/mqtt

BACKEND_PORT=3001
NODE_ENV=development

NEXT_PUBLIC_APP_NAME=PitWall
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:3001/ws
