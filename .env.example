# OpenF1 credentials
# Backend-only. Never expose these with NEXT_PUBLIC_ prefixes.
OPENF1_USERNAME=your_openf1_username
OPENF1_PASSWORD=your_openf1_password

# Backend configuration
BACKEND_PORT=3001
NODE_ENV=development
DATA_MODE=mock

# Frontend public configuration
NEXT_PUBLIC_APP_NAME=PitWall
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:3001/ws
